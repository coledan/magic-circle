# Path to the SQLite database file.
# Local dev: a relative path in the repo.
# Production (Railway/Fly/Render): an absolute path on a mounted persistent volume,
# e.g. /data/magic-circle.db
DATABASE_PATH=./magic-circle.db

# What the wordmark displays in the header.
# Each deployed instance picks its own.
INSTANCE_NAME=magic circle

# Port the Express server listens on. Railway sets this automatically in production.
PORT=3000

# Set to 1 in local dev to seed six starter threads on an empty database, so
# typography and layout have substantive content to render against. Leave
# unset on a deployed instance — the first real visitor should land in the
# empty room and draw the circle themselves.
SEED_DEV_DATA=1
