<main class="content">
  <% if (threads.length === 0) { %>
    <div class="empty-state">
      <div class="circle-wrap">
        <svg class="circle-mark" viewBox="0 0 360 360" aria-hidden="true">
          <!-- Ring drawn from 12 o'clock, clockwise -->
          <circle
            class="ring"
            cx="180" cy="180" r="160"
            fill="none"
            stroke-width="1.5"
            stroke-linecap="round"
            transform="rotate(-90 180 180)"
          />
          <!-- Spark with soft glow, rotates around center in sync with the leading edge -->
          <g class="spark-group">
            <circle class="spark-glow" cx="180" cy="20" r="9" />
            <circle class="spark-core" cx="180" cy="20" r="3.2" />
          </g>
        </svg>
        <!-- Three writing symbols, HTML text to avoid SVG baseline clipping on iOS -->
        <div class="symbol-stack" aria-hidden="true">
          <span class="symbol symbol-1">¶</span>
          <span class="symbol symbol-2">※</span>
          <span class="symbol symbol-3">◆</span>
        </div>
      </div>
      <a href="/threads/new" class="begin-link">begin</a>
    </div>
  <% } else { %>
    <% threads.forEach(function (t) { %>
      <div class="thread-row">
        <a href="/threads/<%= t.id %>" class="thread-title"><%= t.title %></a>
        <div class="meta">
          <span class="author"><%= t.author %></span>
          <span class="sep">◆</span>
          <span><%= t.last_activity_literary %></span>
        </div>
      </div>
    <% }) %>
  <% } %>
</main>
