<main class="content">
  <a href="/" class="back-link">← all threads</a>
  <h1 class="thread-page-title"><%= thread.title %></h1>

  <% posts.forEach(function (p) { %>
    <article class="post" id="post-<%= p.id %>">
      <div class="post-body">
        <% p.paragraphs.forEach(function (para) { %>
          <p><%= para %></p>
        <% }) %>
      </div>
      <div class="meta">
        <span class="author"><%= p.handle %></span>
        <span class="sep">◆</span>
        <span><%= p.timestamp_literary %></span>
      </div>
    </article>
  <% }) %>

  <div class="composer-block">
    <div class="composer-label">add a reply</div>
    <form method="post" action="/threads/<%= thread.id %>/reply">
      <% if (composer.error) { %>
        <div class="composer-error" role="alert"><%= composer.error %></div>
      <% } %>
      <textarea
        name="body"
        class="reply-textarea"
        placeholder="take your time with this."
        aria-label="reply"
        maxlength="10000"
      ><%= composer.body %></textarea>
      <div class="handle-row">
        <span class="handle-label">posting as</span>
        <input
          type="text"
          name="handle"
          class="handle-input"
          placeholder="your handle"
          aria-label="handle"
          value="<%= composer.handle %>"
          maxlength="32"
        >
      </div>
      <button class="submit-btn" type="submit">post reply</button>
    </form>
  </div>
</main>
